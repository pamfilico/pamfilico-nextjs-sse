  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "ioredis": "^5.0.0",
    "jsdom": "^26.0.0",
    "react": "^19.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.2.0"
  },
  "author": "Pamfilico",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pamfilico/pamfilico-nextjs-sse.git"
  }
