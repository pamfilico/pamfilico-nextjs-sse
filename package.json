{
  "name": "@pamfilico/nextjs-sse",
  "version": "0.1.0",
  "description": "SSE infrastructure for Next.js: provider, hook, API routes, and EventListener component",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
